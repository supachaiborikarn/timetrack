# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
.env*.local

# sensitive data dumps / exports / PII (NEVER commit)
# NOTE: prisma/migrations/*.sql are schema migrations and remain tracked.
/backup.sql
/*.dump
/*.bak
/supabase_export.json
*_export.json
/cleaned_staff.csv
/ai_ready_schedule_std.csv
/staff*.csv
credentials*.json
*credentials*.txt
